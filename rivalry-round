/* PAGE HERO */
.page-hero {
  text-align:center; padding:3.5rem 2rem 2.5rem;
  border-bottom:1px solid var(--border);
  background:linear-gradient(180deg, rgba(139,26,26,0.08) 0%, transparent 100%);
}
.page-eyebrow {
  font-family:'Oswald',sans-serif; font-size:0.72rem; letter-spacing:3px;
  text-transform:uppercase; color:var(--red); margin-bottom:0.75rem;
}
.page-title {
  font-family:'Bebas Neue',sans-serif; font-size:clamp(3rem,8vw,5.5rem);
  letter-spacing:5px; color:#fff; line-height:1;
}
.page-subtitle {
  font-family:'Oswald',sans-serif; font-size:1rem; letter-spacing:2px;
  color:var(--text-muted); margin-top:0.5rem;
}

/* MAIN LAYOUT */
.main { max-width:900px; margin:0 auto; padding:3rem 1.5rem 5rem; }

/* SECTION HEADER */
.section-header {
  display:flex; align-items:center; gap:1rem;
  margin-bottom:2rem;
}
.section-icon {
  width:44px; height:44px; border-radius:10px;
  background:rgba(200,169,81,0.12); border:1px solid rgba(200,169,81,0.2);
  display:flex; align-items:center; justify-content:center;
  font-size:1.2rem; flex-shrink:0;
}
.section-label {
  font-family:'Bebas Neue',sans-serif; font-size:1.8rem; letter-spacing:3px; color:#fff;
}
.section-sub {
  font-family:'Oswald',sans-serif; font-size:0.75rem; letter-spacing:2px;
  text-transform:uppercase; color:var(--text-muted);
}

/* INTRO BLURB */
.intro-blurb {
  font-family:'Oswald',sans-serif; font-size:0.92rem; letter-spacing:0.5px;
  color:#8fa8be; line-height:1.8; margin-bottom:2.5rem;
  padding:1.5rem 2rem; border-left:3px solid var(--red);
  background:rgba(139,26,26,0.05); border-radius:0 10px 10px 0;
}

/* MATCH CARDS */
.matches { display:flex; flex-direction:column; gap:1.25rem; margin-bottom:3rem; }

.match-card {
  background:var(--mid); border:1px solid var(--border);
  border-radius:14px; overflow:hidden;
  transition:border-color 0.2s;
}
.match-card:hover { border-color:rgba(200,169,81,0.15); }

/* Special card variants */
.match-card.rivalry     { border-color:rgba(200,169,81,0.3); }
.match-card.hatred      { border-color:rgba(139,26,26,0.4); }
.match-card.grudge      { border-color:rgba(200,169,81,0.25); }
.match-card.blood       { border-color:rgba(200,100,100,0.35); }
.match-card.gathering   { border-color:rgba(100,180,100,0.25); }
.match-card.mates       { border-color:rgba(100,150,200,0.3); }

.match-top {
  display:flex; align-items:center; justify-content:space-between;
  padding:0.65rem 1.25rem;
  border-bottom:1px solid var(--border);
}
.match-label {
  font-family:'Oswald',sans-serif; font-size:0.65rem; letter-spacing:2.5px;
  text-transform:uppercase; color:var(--text-muted);
}
.match-badge {
  font-family:'Oswald',sans-serif; font-size:0.65rem; letter-spacing:2px;
  text-transform:uppercase; padding:0.2rem 0.7rem; border-radius:100px;
}
.match-badge.badge-grudge    { background:rgba(200,169,81,0.12); color:var(--gold); border:1px solid rgba(200,169,81,0.3); }
.match-badge.badge-hatred    { background:rgba(139,26,26,0.18); color:#e06060; border:1px solid rgba(139,26,26,0.4); }
.match-badge.badge-blood     { background:rgba(200,80,80,0.12); color:#e08080; border:1px solid rgba(200,80,80,0.35); }
.match-badge.badge-gather    { background:rgba(100,200,100,0.1); color:#7ec87e; border:1px solid rgba(100,200,100,0.3); }
.match-badge.badge-mates     { background:rgba(100,150,220,0.1); color:#8ab4e8; border:1px solid rgba(100,150,220,0.3); }
.match-badge.badge-classic   { background:rgba(200,169,81,0.12); color:var(--gold); border:1px solid rgba(200,169,81,0.3); }

.match-body {
  display:grid; grid-template-columns:1fr auto 1fr;
  align-items:center; padding:1.5rem 1.5rem 1.25rem; gap:1rem;
}

/* Team photo + name layout */
.match-team { text-align:center; display:flex; flex-direction:column; align-items:center; gap:0.6rem; }
.match-team img {
  width:72px; height:72px; border-radius:50%;
  object-fit:cover; border:2px solid rgba(200,169,81,0.35);
  background:var(--navy);
}
.match-team-name {
  font-family:'Bebas Neue',sans-serif; font-size:1.25rem; letter-spacing:2px;
  color:#fff; line-height:1.1;
}
.match-team-name.home { color:var(--gold); }

.match-vs { text-align:center; flex-shrink:0; }
.match-vs-text {
  font-family:'Oswald',sans-serif; font-size:0.7rem; letter-spacing:3px;
  text-transform:uppercase; color:#304558;
}
.match-vs-icon {
  font-family:'Bebas Neue',sans-serif; font-size:2rem;
  color:var(--red); letter-spacing:1px; margin-top:0.1rem;
  line-height:1;
}

.match-analysis {
  padding:0 1.5rem 1.25rem;
  font-family:'Oswald',sans-serif; font-size:0.88rem;
  letter-spacing:0.5px; color:#8fa8be; line-height:1.7;
}
.match-analysis strong { color:#fff; }

/* TAKEAWAYS */
.takeaways-card {
  background:var(--mid); border:1px solid var(--border);
  border-radius:14px; padding:2rem;
}
.takeaways-title {
  font-family:'Bebas Neue',sans-serif; font-size:1.5rem; letter-spacing:3px;
  color:var(--gold); margin-bottom:1.25rem;
}
.takeaways-list { list-style:none; display:flex; flex-direction:column; gap:0.75rem; }
.takeaways-list li {
  font-family:'Oswald',sans-serif; font-size:0.88rem; letter-spacing:0.5px;
  color:#8fa8be; line-height:1.6;
  padding-left:1.25rem; position:relative;
}
.takeaways-list li::before {
  content:'▸'; position:absolute; left:0; color:var(--red); font-size:0.7rem; top:0.15rem;
}
.takeaways-list li strong { color:#fff; }

.sign-off {
  margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--border);
  font-family:'Oswald',sans-serif; font-size:0.88rem; letter-spacing:0.5px;
  color:#8fa8be; line-height:1.8;
}
.sign-off strong { color:#fff; }

footer {
  text-align:center; padding:2rem; color:#253545;
  font-size:0.78rem; font-family:'Oswald',sans-serif; letter-spacing:1px;
  border-top:1px solid var(--border);
}
